# Database
DATABASE_URL="file:./dev.db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-this-refresh-secret-too"
JWT_REFRESH_EXPIRES_IN="30d"

# API
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="*"

# Web — для доступа с других устройств в локальной сети замените localhost на IP вашего ПК:
# NEXT_PUBLIC_API_URL="http://192.168.1.100:4000"
# NEXT_PUBLIC_WS_URL="http://192.168.1.100:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# Admin bootstrap
ADMIN_EMAIL="admin@nexora.io"
ADMIN_PASSWORD="NexoraAdmin2026!"
